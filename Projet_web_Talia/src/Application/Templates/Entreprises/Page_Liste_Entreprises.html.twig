{% extends "Bases/Base.html.twig" %}

{% block title %}Liste des Entreprises{% endblock %}

{% block content %}

    <h1>Liste des Entreprises</h1>
    <div class="text-center my-4">
        <a href="/Inscription-Entreprise" class="btn" style="background-color: #73986f; color: white;">
            Ajouter une entreprise
        </a>
    </div>


<div class="card shadow-sm">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th>ID</th>
                    <th>Nom</th>
                    <th>Secteur</th>
                    <th>Statut</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                {% for ent in entreprises %}
                <tr>
                    <td>{{ ent.id }}</td>
                    <td><strong>{{ ent.nom }}</strong></td>
                    <td>{{ ent.secteur }}</td>
                    <td>
                        <span class="badge {% if ent.statut == 'Actif' %}bg-success{% else %}bg-secondary{% endif %}">
                            {{ ent.statut }}
                        </span>
                    </td>
                    <td class="text-end">
                        <a href="#" class="btn btn-sm btn-outline-info">Voir</a>
                    </td>
                </tr>
                {% else %}
                <tr>
                    <td colspan="5" class="text-center py-4">Aucune entreprise trouvée.</td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>




{% endblock %}