{% extends "Bases/base.html.twig" %}

{% block content %}
	<div class="main-container" style="background-color: #eed4cb; padding: 50px; min-height: 100vh;">
		<div
			class="container" style="background-color: #ffffff; border-radius: 12px; padding: 30px; max-width: 700px; border: 1px solid #a0a890; margin: auto;">

			{# URL ACTION #}
			{% if type == "Etudiants_ajout" %}
				{% set action_url = "/users/inscription-etudiant" %}
			{% elseif type == "Etudiants_modifier" %}
				{% set action_url = "/users/etudiant/modifier/" ~ etudiant.id %}
			{% elseif type == "Pilote_ajout" %}
				{% set action_url = "/users/inscription-pilote" %}
			{% elseif type == "Pilote_modifier" %}
				{% set action_url = "/users/pilote/modifier/" ~ pilote.id %}
			{% endif %}

			{# TITRE #}
			<h2 class="text-center mb-4" style="color: #a0a890;">
				{% if type == "Etudiants_modifier" or type == "Pilote_modifier" %}
					Modifier
				{% else %}
					Ajouter
				{% endif %}

				{% if type == "Etudiants_ajout" or type == "Etudiants_modifier" %}
					un Étudiant
				{% else %}
					un Pilote
				{% endif %}
			</h2>

			<form method="POST" action="{{ action_url }}" enctype="multipart/form-data">

				{% set user_obj = etudiant ?? pilote ?? null %}

				<div class="mb-3">
					<label>Nom</label>
					<input type="text" name="nom" class="form-control" value="{{ user_obj.nom ?? '' }}" required>
				</div>

				<div class="mb-3">
					<label>Prénom</label>
					<input type="text" name="prenom" class="form-control" value="{{ user_obj.prenom ?? '' }}" required>
				</div>

				<div class="mb-3">
					<label>Email</label>
					<input type="email" name="email" class="form-control" value="{{ user_obj.email ?? '' }}" required>
				</div>

				{# MOT DE PASSE UNIQUEMENT EN AJOUT #}
				{% if type == "Etudiants_ajout" or type == "Pilote_ajout" %}
					<div class="mb-3">
						<label>Mot de passe</label>
						<input type="password" name="mot_de_passe" class="form-control" required>
					</div>
				{% endif %}

				{# ETUDIANT #}
				{% if type == "Etudiants_ajout" or type == "Etudiants_modifier" %}
					<div class="mb-3">
						<label>Adresse</label>
						<input type="text" name="adresse" class="form-control" value="{{ etudiant.adresse ?? '' }}">
					</div>

					<div class="mb-3">
						<label>Ville</label>
						<input type="text" name="ville" class="form-control" value="{{ etudiant.ville ?? '' }}">
					</div>

					<div class="mb-3">
						<label>Région</label>
						<input type="text" name="region" class="form-control" value="{{ etudiant.region ?? '' }}">
					</div>
				{% endif %}

				{# PILOTE #}
				{% if type == "Pilote_ajout" or type == "Pilote_modifier" %}
					<div class="mb-3">
						<label>Localisation</label>
						<input type="text" name="localisation" class="form-control" value="{{ pilote.localisation ?? '' }}">
					</div>
				{% endif %}

				{# CAMPUS #}
				<div class="mb-3">
					<label>Campus</label>
					<select name="campus" class="form-select" required>
						{% for c in campusList %}
							<option value="{{ c.nomVille }}" {% if user_obj and user_obj.campus and user_obj.campus.nomVille == c.nomVille %} selected {% endif %}>
								{{ c.nomVille }}
							</option>
						{% endfor %}
					</select>
				</div>

				{# IMAGE #}
				<div class="mb-3">
					<label>Image de profil</label>
					<input type="file" name="image_profil" class="form-control" {% if type == "Etudiants_ajout" or type == "Pilote_ajout" %} required {% endif %}>
				</div>

				<button type="submit" class="btn w-100" style="background-color:#a0a890; color:white;">
					{% if type == "Etudiants_modifier" or type == "Pilote_modifier" %}
						Modifier
					{% else %}
						Ajouter
					{% endif %}
				</button>

			</form>
		</div>
	</div>
{% endblock %}
