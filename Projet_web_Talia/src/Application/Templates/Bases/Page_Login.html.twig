{% extends 'Bases/Base.html.twig' %}
{% block style %}
	<style>

		.col {
			padding: 20px;
			background-color: #ffffff;
			border: 1px solid #e0e0e0;
			border-radius: 12px;
			box-shadow: 0 4px 6px rgba(0, 0, 0, 0.05);
			margin-bottom: 15px;
			transition: transform 0.2s ease;
		}
	</style>
{% endblock %}
{% block content %}

	<div class="col-8 ">
		<label for="Nom de l'étudiant" class="form-label pt-2 m-2">Email</label>
		<input type="email" class="form-control" id="Email de connexion" placeholder="Entrez votre adresse mail">
	</div>
	<div class="col-8">
		<label for="Prénom de l'étudiant" class="form-label pt-2 m-2">Mot de passe
		</label>
		<input type="password" class="form-control" id="Mdp de connexion" placeholder="Entrez votre mot de passe">
	</div>
	<center>
		<div class="col-12 pt-4 m-2">
			<button type="connection" class="btn btn-primary">Se connecter</button>
		</div>
	</center>
{% endblock %}
