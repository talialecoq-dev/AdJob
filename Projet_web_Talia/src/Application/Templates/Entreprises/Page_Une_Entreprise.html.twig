<div class="container-fluid px-4 my-5">
	<div class="row row-cols-1 row-cols-md-4 g-4">

		{% for entreprise in entreprises %}
			<div class="col">
				<div class="card border-0 overflow-hidden h-100" style="border-radius:2rem; background-color:#97a48a;">

					<div style="height:220px; overflow:hidden; border-radius:2rem 2rem 0 0;">
						{% if entreprise.image %}
							<img src="/uploads/{{ entreprise.image }}" alt="{{ entreprise.nom }}" style="width:100%; height:100%; object-fit:cover;">
						{% else %}
							<div class="d-flex align-items-center justify-content-center h-100" style="background-color:#e0c7bf;">
								<span class="text-muted" style="font-size:1.2rem;">erreur image</span>
							</div>
						{% endif %}
					</div>

					<div class="card-body px-4 pt-4 pb-4 d-flex flex-column gap-3">

						<h5 class="text-white fw-bold mb-0">{{ entreprise.nom }}</h5>

						<div class="d-flex flex-wrap gap-2">
							<span class="badge rounded-pill border text-dark fw-normal px-3 py-2" style="background-color:#ffffff;">
								{{ entreprise.secteur }}
							</span>
						</div>

						<div class="d-flex gap-2 mt-auto flex-wrap">
							<a href="/entreprise/{{ entreprise.nom|url_encode }}/offres" class="btn flex-fill" style="background-color:#e0c7bf; color:black; border-radius:0.6rem;">
								En savoir plus
							</a>
							<a href="{{ entreprise.siteWeb }}" target="_blank" class="btn flex-fill" style="background-color:#e0c7bf; color:black; border:none; border-radius:0.6rem;">
								Visiter le site
							</a>
						</div>

					</div>
				</div>
			</div>
		{% endfor %}

	</div>
</div>