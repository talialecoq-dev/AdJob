
  <head>
    <meta charset="utf-8">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <title>AdJob</title>
  </head>
  <body> 
<div class="col ">
  <label for="Nom de l'entreprise" class="form-label">Nom de l'entreprise</label>
  <input type="text" class="form-control" id="Nom de l'entreprise" placeholder="Entrez le nom de votre entreprise">
</div> 
<div class="row g-3">
  <div class="col ">
  <label for="Nom de l'entreprise" class="form-label">Téléphone de l'entreprise</label>
  <input type="num" class="form-control" id="Nom de l'entreprise" placeholder="Entrez le téléphone de votre entreprise">
</div>
<div class="col ">  
    <label for="Email de l'entreprise" class="form-label">Email</label>
    <input type="email" class="form-control" id="Email de l'entreprise" placeholder="Entrez l'adresse email de contact de votre entreprise">
</div>
  </div>


<div class="row g-3">   
<div class="col ">
  <label for="Secteur d'activité de l'entreprise" class="form-label">Secteur d'activité </label>
  <input type="text" class="form-control" id="Adresse de l'entreprise" placeholder="Entrez le secteur d'activité de votre entreprise">
</div>
<div class="col ">
  <label for="Site internet de l'entreprise" class="form-label">Site Internet </label>
  <input type="text" class="form-control" id="Adresse de l'entreprise" placeholder="Entrez le site internet de votre entreprise">
</div>
</div>

  <div class="col ">
  <label for="Adresse de l'entreprise" class="form-label">Adresse Postal </label>
  <input type="text" class="form-control" id="Adresse de l'entreprise" placeholder="Entrez l'adresse Postal de votre entreprise">
</div>
<form class="row g-3">
  <div class="col-md-6">
    <label for="inputCity" class="form-label">City</label>
    <input type="text" class="form-control" id="inputCity" placeholder="Entrez la ville de votre entreprise ">
  </div>
  <div class="col-md-4">
    <label for="inputState" class="form-label">Region</label>
    <select id="inputState" class="form-select">
    <option selected>Choisir votre region </option>
    <option>Auvergne-Rhône-Alpes</option>
    <option>Bourgogne-Franche-Comté</option>
    <option>Bretagne</option>
    <option>Centre-Val de Loire</option>
    <option>Grand Est</option>
    <option>Hauts-de-France</option>
    <option>Ile-de-France</option> 
    <option>Normandie</option>
    <option>Nouvelle-Aquitaine</option>
    <option>Occitanie</option>
    <option>Pays de la Loire</option>
    <option>Provence Alpes Côte d’Azur</option>
    </select>
  </div>
  </form>
  <div class="col-md-6">
  <label for="formFile" class="form-label">Choisissez une image</label>
  <input class="form-control" type="file" id="formFile" accept="image/*">
</div>
</body>
