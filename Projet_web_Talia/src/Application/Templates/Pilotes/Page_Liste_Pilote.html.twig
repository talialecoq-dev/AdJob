{% extends "Bases/Base.html.twig" %}

{% block content %}

	<style>
		.btn-modifier {
			background-color: #73986f;
			color: white;
			margin-right: 5px;
		}
		.btn-supprimer {
			background-color: #e0c7bf;
			color: white;
		}
		th,
		td {
			text-align: center;
			vertical-align: middle;
		}
		.actions-col {
			text-align: right;
			white-space: nowrap;
		}
	</style>

	<h1>Liste de tous les Pilotes</h1>

	<div class="text-center my-4">
		<a href="/Inscription-Pilote" class="btn btn-modifier">
			Ajouter un(e) pilote
		</a>
	</div>

	<table class="table">
		<thead>
			<tr>
				<th scope="col">Id</th>
				<th scope="col">Prénom</th>
				<th scope="col">Nom</th>
				<th scope="col">Email</th>
				<th scope="col">Campus</th>
				<th scope="col">Localisation</th>
				<th scope="col">Image</th>
				<th scope="col" class="actions-col"></th>
			</tr>
		</thead>
		<tbody>
			<th scope="row">{{pilotes.Id}}</th>
			<td>{{pilotes.prénom}}</td>
			<td>{{pilotes.nom}}</td>
			<td>{{pilotes.email}}</td>
			<td>{{pilotes.campus}}</td>
			<td>{{pilotes.localisation}}</td>
			<td>{{pilotes.image}}</td>
			<td class="actions-col">

				<a href="/Modifier-Pilote" class="btn btn-modifier">Modifier</a>
				<form method="POST" action="/Supprimer-Pilote/{{ pilote.id }}">
					<button type="submit" class="btn btn-supprimer">Supprimer</button>
				</form>
			</td>
		</tbody>
	</tr>
</tbody></table>{% endblock %}
