{% extends "Bases/Base.html.twig" %}

{% block content %}
	<div class="main-container" style="background-color: #eed4cb; padding: 50px;">
		<div class="container" style="background-color: #ffffff; border-radius: 12px; padding: 30px; max-width: 700px; border: 1px solid #a0a890; margin: auto;">

			{# 1. CALCUL DE L'URL D'ACTION #}
			{# Si le type est Entreprise, on va vers /inscription-entreprise, sinon vers /traitement-inscription #}
			{% set action_url = (type == "Entreprise") ? "/inscription-entreprise" : "/traitement-inscription" %}

			{# 2. DÉBUT DU FORMULAIRE #}
			{# enctype est nécessaire seulement si on ajoute un étudiant avec une photo #}
				<form method="POST" action="{{ action_url }}" {% if type == "Etudiants_ajout" %} enctype="multipart/form-data" {% endif %}> {% if type == "Etudiants" or type == "Etudiants_ajout" %}
					{# --- BLOC ÉTUDIANT --- #}
					<div class="mb-3">
						<label for="nom_etudiant" class="form-label pt-2 m-2">Nom de l'étudiant</label>
						<input type="text" name="nom" class="form-control" id="nom_etudiant" placeholder="Entrez le nom" style="border: 1px solid #a0a890;" required>
					</div>
					<div class="mb-3">
						<label for="prenom_etudiant" class="form-label pt-2 m-2">Prénom de l'étudiant</label>
						<input type="text" name="prenom" class="form-control" id="prenom_etudiant" placeholder="Entrez le prénom" style="border: 1px solid #a0a890;" required>
					</div>
					<div class="mb-3">
						<label for="email" class="form-label pt-2 m-2">Email</label>
						<input type="email" name="email" class="form-control" id="email" placeholder="exemple@mail.com" style="border: 1px solid #a0a890;" required>
					</div>
					<div class="mb-3">
						<label for="adresse" class="form-label pt-2 m-2">Adresse Postale</label>
						<input type="text" name="adresse" class="form-control" id="adresse" style="border: 1px solid #a0a890;" required>
					</div>

					<div class="row g-3">
						<div class="col-md-6 mb-3">
							<label for="ville" class="form-label pt-2 m-2">Ville</label>
							<input type="text" name="ville" class="form-control" id="ville" style="border: 1px solid #a0a890;" required>
						</div>
						<div class="col-md-6 mb-3">
							<label for="region" class="form-label pt-2 m-2">Région</label>
							<select id="region" name="region" class="form-select" style="border: 1px solid #a0a890;" required>
								<option selected>Choisir...</option>
								<option value="ARA">Auvergne-Rhône-Alpes</option>
								<option value="BFC">Bourgogne-Franche-Comté</option>
								<option value="BRE">Bretagne</option>
								<option value="IDF">Ile-de-France</option>
								<option value="NOR">Normandie</option>
								<option value="NAQ">Nouvelle-Aquitaine</option>
								<option value="OCC">Occitanie</option>
								<option value="PAC">Provence-Alpes-Côte d'Azur</option>
							</select>
						</div>
					</div>


					{% if type == "Etudiants_ajout" %}
						<div class="mb-3">
							<label for="image_profil" class="form-label pt-2 m-2">Choisissez une image de profil</label>
							<input class="form-control" type="file" name="image_profil" id="image_profil" accept="png, jpg, jpeg" required style="border: 1px solid #a0a890;" required>
						</div>
					{% endif %}

					{% if type == "Etudiants" %}
						<div class="mb-3">
							<label for="image_profil" class="form-label pt-2 m-2">Choisissez une image de profil</label>
							<input class="form-control" type="file" name="image_profil" id="image_profil" accept="png, jpg, jpeg" required style="border: 1px solid #a0a890;" required>
						</div>
					{% endif %}


				{% elseif type == "Pilote" %}
					{# --- BLOC PILOTE --- #}
					<div class="mb-3">
						<label for="nom_pilote" class="form-label pt-2 m-2">Nom du pilote</label>
						<input type="text" name="nom" class="form-control" id="nom_pilote" placeholder="Nom du pilote" style="border: 1px solid #a0a890;" required>
					</div>
					<div class="mb-3">
						<label for="prenom_pilote" class="form-label pt-2 m-2">Prénom du pilote</label>
						<input type="text" name="prenom" class="form-control" id="prenom_pilote" placeholder="Prénom du pilote" style="border: 1px solid #a0a890;" required>
					</div>
					<div class="mb-3">
						<label for="image_profil" class="form-label pt-2 m-2">Choisissez une image de profil</label>
						<input class="form-control" type="file" name="image_profil" id="image_profil" accept="png, jpg, jpeg" required style="border: 1px solid #a0a890;" required>
					</div>

				{% else %}
					{# --- BLOC ENTREPRISE (PAR DÉFAUT) --- #}
					<div class="mb-3">
						<label for="nom_entreprise" class="form-label pt-2 m-2">Nom de l'entreprise</label>
						<input type="text" name="nom_entreprise" class="form-control" id="nom_entreprise" placeholder="Nom de votre entreprise" style="border: 1px solid #a0a890;" required>
					</div>

					<div class="mb-3">
						<label for="tel" class="form-label pt-2 m-2">Téléphone de l'entreprise</label>
						<input type="tel" name="telephone" class="form-control" id="tel" placeholder="0102030405" style="border: 1px solid #a0a890;" required>
					</div>

					<div class="row g-3">
						<div class="col-md-6 mb-3">
							<label for="secteur" class="form-label pt-2 m-2">Secteur d'activité</label>
							<input type="text" name="secteur" class="form-control" id="secteur" placeholder="Ex: Informatique" style="border: 1px solid #a0a890;" required>
						</div>
						<div class="col-md-6 mb-3">
							<label for="site" class="form-label pt-2 m-2">Site Internet</label>
							<input type="url" name="site_web" class="form-control" id="site" placeholder="https://..." style="border: 1px solid #a0a890;" required>
						</div>
					</div>

					<div class="mb-3">
						<label for="email_ent" class="form-label pt-2 m-2">Email de contact</label>
						<input type="email" name="email" class="form-control" id="email_ent" placeholder="contact@entreprise.com" style="border: 1px solid #a0a890;" required>
					</div>
					<div class="mb-3">
						<label for="image_profil" class="form-label pt-2 m-2">Choisissez une image de profil</label>
						<input class="form-control" type="file" name="image_profil" id="image_profil" accept="png, jpg, jpeg" required style="border: 1px solid #a0a890;" required>
					</div>
				{% endif %}

				{# 3. BOUTON DE VALIDATION UNIQUE #}
				<div class="col-12 pt-4">
					<button type="submit" class="btn w-100" accept=".png, .jpg, .jpeg" style="background-color: #a0a890; color: white; border: none; padding: 12px; font-weight: bold; border-radius: 25px;" required>
						<div class="invalid-feedback">
							Merci de sélectionner une image.
						</div>
						{% if type == "Etudiants_ajout" %}
							Ajouter l'étudiant
						{% elseif type == "Etudiants" %}
							Enregistrer les modifications
						{% elseif type == "Pilote" %}
							Inscrire le pilote
						{% else %}
							S'inscrire (Entreprise)
						{% endif %}
					</button>
				</div>

			</form>
		</div>
	</div>


	<script>
		document.querySelector("form").addEventListener("submit", function (e) {

const filesInputs = document.querySelectorAll("input[type='file']");
const allowedExtensions = ["png", "jpg", "jpeg"];

for (let input of filesInputs) {

if (input.files.length > 0) {

const file = input.files[0];
const extension = file.name.split('.').pop().toLowerCase();

if (! allowedExtensions.includes(extension)) {
alert("Seuls les fichiers PNG, JPG ou JPEG sont autorisés.");
e.preventDefault();
return;
}

}

}

});
	</script>
{% endblock %}
