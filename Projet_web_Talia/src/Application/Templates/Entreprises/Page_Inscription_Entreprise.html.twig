{% extends "Bases/Base.html.twig" %}

{% block content %}
	<div class="main-container" style="background-color: #eed4cb; padding: 50px;">
		<div class="container" style="background-color: #ffffff; border-radius: 12px; padding: 30px; max-width: 700px; border: 1px solid #a0a890; margin: auto;">

			{% if type == "Entreprise" or type == "Entreprise_Ajout" %}
				{% set action_url = "/inscription-entreprise" %}
			{% elseif type == "Entreprise_Modifier" %}
				{% set action_url = "/Update-Entreprise/" ~ entreprise.id %}
			{% elseif type == "Etudiants_ajout" %}
				{% set action_url = "/Inscription-Étudiant" %}
			{% elseif type == "Etudiants" %}
				{% set action_url = "/Update-Étudiant/" ~ etudiant.id %}
			{% elseif type == "Pilote" %}
				{% set action_url = "/Inscription-Pilote" %}
			{% elseif type == "Pilote_Modifier" %}
				{% set action_url = "/Update-Pilote/" ~ pilote.id %}
			{% else %}
				{% set action_url = "/traitement-inscription" %}
			{% endif %}

			<form method="POST" action="{{ action_url }}" enctype="multipart/form-data">

				{% if type == "Etudiants" or type == "Etudiants_ajout" %}

					<div class="mb-3">
						<label class="form-label pt-2 m-2">Nom</label>
						<input type="text" name="nom" class="form-control" value="{{ etudiant.nom ?? '' }}" required>
					</div>

					<div class="mb-3">
						<label class="form-label pt-2 m-2">Prénom</label>
						<input type="text" name="prenom" class="form-control" value="{{ etudiant.prenom ?? '' }}" required>
					</div>

					<div class="mb-3">
						<label class="form-label pt-2 m-2">Email</label>
						<input type="email" name="email" class="form-control" value="{{ etudiant.email ?? '' }}" required>
					</div>

					<div class="mb-3">
						<label class="form-label pt-2 m-2">Adresse</label>
						<input type="text" name="adresse" class="form-control" value="{{ etudiant.adresse ?? '' }}" required>
					</div>

					<div class="row g-3">
						<div class="col-md-6 mb-3">
							<label class="form-label pt-2 m-2">Ville</label>
							<input type="text" name="ville" class="form-control" value="{{ etudiant.ville ?? '' }}" required>
						</div>

						<div class="col-md-6 mb-3">
							<label class="form-label pt-2 m-2">Région</label>
							<select name="region" class="form-select" required>
								<option value="">Choisir...</option>
								<option value="ARA" {{ etudiant.region == 'ARA' ? 'selected' : '' }}>Auvergne-Rhône-Alpes</option>
								<option value="BFC" {{ etudiant.region == 'BFC' ? 'selected' : '' }}>Bourgogne-Franche-Comté</option>
								<option value="BRE" {{ etudiant.region == 'BRE' ? 'selected' : '' }}>Bretagne</option>
								<option value="IDF" {{ etudiant.region == 'IDF' ? 'selected' : '' }}>Île-de-France</option>
								<option value="NOR" {{ etudiant.region == 'NOR' ? 'selected' : '' }}>Normandie</option>
								<option value="NAQ" {{ etudiant.region == 'NAQ' ? 'selected' : '' }}>Nouvelle-Aquitaine</option>
								<option value="OCC" {{ etudiant.region == 'OCC' ? 'selected' : '' }}>Occitanie</option>
								<option value="PAC" {{ etudiant.region == 'PAC' ? 'selected' : '' }}>Provence-Alpes-Côte d'Azur</option>
							</select>
						</div>
					</div>

					<div class="mb-3">
						<label class="form-label pt-2 m-2">Image de profil</label>
						<input type="file" name="image_profil" class="form-control" accept="png, jpg, jpeg" {% if type == "Etudiants_ajout" %} required {% endif %}>
					</div>

				{% elseif type == "Pilote" or type == "Pilote_Modifier" %}

					<div class="mb-3">
						<label class="form-label pt-2 m-2">Nom du pilote</label>
						<input type="text" name="nom" class="form-control" value="{{ pilote.nom ?? '' }}" placeholder="Nom du pilote" style="border: 1px solid #a0a890;" required>
					</div>
					<div class="mb-3">
						<label class="form-label pt-2 m-2">Prénom du pilote</label>
						<input type="text" name="prenom" class="form-control" value="{{ pilote.prenom ?? '' }}" placeholder="Prénom du pilote" style="border: 1px solid #a0a890;" required>
					</div>
					<div class="mb-3">
						<label class="form-label pt-2 m-2">Email du pilote</label>
						<input type="email" name="email" class="form-control" value="{{ pilote.email ?? '' }}" placeholder="Mail du pilote" style="border: 1px solid #a0a890;" required>
					</div>
					<div class="mb-3">
						<label class="form-label pt-2 m-2">Campus du pilote</label>
						<input type="text" name="campus" class="form-control" value="{{ pilote.campus ? pilote.campus.nomVille : '' }}" placeholder="Campus du pilote" style="border: 1px solid #a0a890;" required>
					</div>
					<div class="mb-3">
						<label class="form-label pt-2 m-2">Localisation du pilote</label>
						<input type="text" name="localisation" class="form-control" value="{{ pilote.localisation ?? '' }}" placeholder="Localisation du pilote" style="border: 1px solid #a0a890;" required>
					</div>
					<div class="mb-3">
						<label class="form-label pt-2 m-2">Choisissez une image de profil</label>
						<input class="form-control" type="file" name="image_profil" accept="png, jpg, jpeg" style="border: 1px solid #a0a890;" {% if type == "Pilote" %} required {% endif %}>
					</div>


				{% else %}
					<div class="mb-3">
						<label class="form-label pt-2 m-2">Nom de l'entreprise</label>
						<input type="text" name="nom_entreprise" class="form-control" value="{{ entreprise.nom ?? '' }}" placeholder="Nom de votre entreprise" style="border: 1px solid #a0a890;" required>
					</div>
					<div class="mb-3">
						<label class="form-label pt-2 m-2">Téléphone de l'entreprise</label>
						<input type="tel" name="telephone" class="form-control" value="{{ entreprise.telephone ?? '' }}" placeholder="0102030405" style="border: 1px solid #a0a890;">
					</div>
					<div class="row g-3">
						<div class="col-md-6 mb-3">
							<label class="form-label pt-2 m-2">Secteur d'activité</label>
							<input type="text" name="secteur" class="form-control" value="{{ entreprise.secteur ?? '' }}" placeholder="Ex: Informatique" style="border: 1px solid #a0a890;" required>
						</div>
						<div class="col-md-6 mb-3">
							<label class="form-label pt-2 m-2">Site Internet</label>
							<input type="url" name="site_web" class="form-control" value="{{ entreprise.siteWeb ?? '' }}" placeholder="https://..." style="border: 1px solid #a0a890;" required>
						</div>
					</div>
					<div class="mb-3">
						<label class="form-label pt-2 m-2">Email de contact</label>
						<input type="email" name="email" class="form-control" value="{{ entreprise.email ?? '' }}" placeholder="contact@entreprise.com" style="border: 1px solid #a0a890;" required>
					</div>
					<div class="mb-3">
						<label class="form-label pt-2 m-2">Choisissez une image de profil</label>
						<input class="form-control" type="file" name="image_profil" accept="png, jpg, jpeg" style="border: 1px solid #a0a890;" {% if type != "Entreprise_Modifier" %} required {% endif %}>
					</div>
				{% endif %}

				<div class="col-12 pt-4">
					<button type="submit" class="btn w-100" style="background-color: #a0a890; color: white; padding: 12px; border-radius: 25px;">
						{% if type == "Etudiants_ajout" %}
							Ajouter l'étudiant
						{% elseif type == "Etudiants" %}
							Enregistrer les modifications
						{% elseif type == "Pilote" %}
							Ajouter le pilote
						{% elseif type == "Pilote_Modifier" %}
							Enregistrer les modifications
						{% elseif type == "Entreprise" or type == "Entreprise_Ajout" %}
							S'inscrire
						{% elseif type == "Entreprise_Modifier" %}
							Enregistrer les modifications
						{% else %}
							S'inscrire
						{% endif %}
					</button>
				</div>

			</form>
		</div>
	</div>
{% endblock %}
