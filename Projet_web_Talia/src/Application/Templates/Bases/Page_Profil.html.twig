{% extends 'Bases/Base.html.twig' %}

{% block title %}Mon Profil - AdJob
{% endblock %}

{% block content %}
	<div class="container py-5" style="max-width: 800px;">
		<div class="card shadow-lg border-0" style="border-radius: 1rem;">
			<div class="card-body p-5">
				<div class="row align-items-center">


					<div class="col-md-4 text-center border-end">
						{% if user.logo %}

							<img src="/uploads/{{ user.logo }}" alt="Photo de {{ user.prenom }}" class="rounded-circle shadow-sm mb-3" style="width: 160px; height: 160px; object-fit: cover; border: 4px solid #97a48a;">
						{% else %}

							<img src="/Images/Image_Profil.png" alt="Photo par défaut" class="rounded-circle shadow-sm mb-3" style="width: 160px; height: 160px; object-fit: cover; border: 4px solid #ccc;">
						{% endif %}

						<h4 class="fw-bold text-dark mb-1">{{ user.prenom }}
							{{ user.nom }}</h4>
						<span class="badge text-uppercase px-3 py-2 mt-2" style="background-color: #97a48a;">
							{{ user.role.value }}
						</span>
					</div>


					<div class="col-md-8 ps-md-5">
						<h5 class="border-bottom pb-2 mb-4" style="color: #4a5d43;">Mes Informations Personnelles</h5>

						<div class="row mb-3">
							<div class="col-sm-4 text-muted fw-bold">Email</div>
							<div class="col-sm-8">{{ user.email }}</div>
						</div>

						{% if user.role.value == 'etudiant' %}
							<div class="row mb-3">
								<div class="col-sm-4 text-muted fw-bold">Adresse</div>
								<div class="col-sm-8">{{ user.adresse ?? 'Non renseignée' }}</div>
							</div>
							<div class="row mb-3">
								<div class="col-sm-4 text-muted fw-bold">Ville</div>
								<div class="col-sm-8">{{ user.ville ?? 'Non renseignée' }}</div>
							</div>
							<div class="row mb-3">
								<div class="col-sm-4 text-muted fw-bold">Région</div>
								<div class="col-sm-8">{{ user.region ?? 'Non renseignée' }}</div>
							</div>
						{% endif %}

						{% if user.role.value == 'pilote' %}
							<div class="row mb-3">
								<div class="col-sm-4 text-muted fw-bold">Localisation</div>
								<div class="col-sm-8">{{ user.localisation ?? 'Non renseignée' }}</div>
							</div>
						{% endif %}

						{% if user.campus %}
							<div class="row mb-3">
								<div class="col-sm-4 text-muted fw-bold">Campus</div>
								<div class="col-sm-8">{{ user.campus.nomVille }}</div>
							</div>
						{% endif %}

						<div class="mt-4">
							<a href="/Profil/Modifier" class="btn btn-sm text-white" style="background-color: #4a5d43;">
								<i class="bi bi-pencil-square"></i>
								Modifier mon profil
							</a>
						</div>
					</div>

				</div>
			</div>
		</div>
	</div>
{% endblock %}
