<!doctype html>
<html lang="fr">
	<head>
		<meta charset="utf-8">
		<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
		<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
		<title>
			{% block title %}AdJob
			{% endblock %}
		</title>
	</head>
	<body>

		{% block navbar %}
			<nav class="navbar navbar-expand-lg" style="background-color: #eceade;">
				<div class="container-fluid">
					<a class="navbar-brand px-3" href="#">
						<img src="Image/Logo.png" alt="ADJOB" width="120" height="120">
					</a>
					<button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarSupportedContent" aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="Toggle navigation">
						<span class="navbar-toggler-icon"></span>
					</button>
					<div class="collapse navbar-collapse justify-content-center">
						<ul class="navbar-nav mb-2 mb-lg-0">
							<li class="nav-item">
								<a class="nav-link px-3" style="font-size: 1.5rem;" href="/"><img src="Images/Image_Maison.png" alt="Accueil" width="30" height="30" class="d-inline-block align-text-top">
									Accueil</a>
							</li>
							<li class="nav-item">
								<a class="nav-link px-3" style="font-size: 1.5rem;" href="/Profil"><img src="Images/Image_Profil.png" alt="Profil" width="30" height="30" class="d-inline-block align-text-top">
									Profil</a>
							</li>
							<li class="nav-item">
								<a class="nav-link px-3" style="font-size: 1.5rem;" href="/Candidatures"><img src="Images/Image_Candidature.png" alt="Candidatures" width="30" height="30" class="d-inline-block align-text-top">
									Candidatures</a>
							</li>

							<li class="nav-item">
								<a class="nav-link px-3" style="font-size: 1.5rem;" href="/Whishlist"><img src="Images/Image_Offre.png" alt="Offres" width="30" height="30" class="d-inline-block align-text-top">
									Ma wishlist</a>
							</li>
							<li class="nav-item dropdown">
								<a class="nav-link dropdown-toggle px-3" style="font-size: 1.5rem;" role="button" data-bs-toggle="dropdown"><img src="Images/Image_Etudiant.png" alt="Étudiants" width="30" height="30" class="d-inline-block align-text-top">
									Étudiants</a>
								<ul class="dropdown-menu">
									<li>
										<a class="dropdown-item" href="/Liste-Étudiants">Les Étudiants</a>
									</li>
									<li>
										<a class="dropdown-item" href="#">Mes Étudiants</a>
									</li>
								</ul>
							</li>
							<li class="nav-item">
								<a class="nav-link px-3" style="font-size: 1.5rem;" href="/Liste-Pilotes"><img src="Images/Image_Pilote.png" alt="Pilotes" width="30" height="30" class="d-inline-block align-text-top">
									Pilotes</a>
							</li>

							<li class="nav-item dropdown">
								<a class="nav-link dropdown-toggle px-3" style="font-size: 1.5rem;" role="button" data-bs-toggle="dropdown"><img src="Images/Image_Entreprise.png" alt="Entreprises" width="30" height="30" class="d-inline-block align-text-top">
									Entreprises</a>
								<ul class="dropdown-menu">
									<li>
										<a class="dropdown-item" href="/Rechercher-Entreprise">Consulter les Entreprises</a>
									</li>
									<li>
										<a class="dropdown-item" href="/Liste-Entreprises">Les Entreprises</a>
									</li>
								</ul>
							</li>
							<li class="nav-item">
								<a class="nav-link px-3" style="font-size: 1.5rem;" href="/Login">Connexion toto</a>
							</li>
						</ul>
					</div>
				</div>
			</nav>
		{% endblock %}

		{% block content %}{% endblock %}
		{% include "Bases/footer.html.twig" %}
	</body>


</html>
