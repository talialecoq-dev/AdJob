{% extends "Bases/Base.html.twig" %}    
{% block title %}Ma wishlist - AdJob{% endblock %}

{% block content %}
<div class="container mt-5">
    <h1 class="mb-4">Ma Wishlist</h1>

 <div class="row">


{% for item in wishlistItems %}

<div class="col-md-4">

<div class="card">

<div class="card-body">

<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="gold" class="bi bi-star-fill" viewBox="0 0 16 16">
  <path d="M3.612 15.443c-.396.2-.86-.149-.746-.592l.83-4.73L.173 6.765c-.33-.314-.158-.888.283-.95l4.898-.696L7.538.792c.197-.39.73-.39.927 0l2.184 4.327 4.898.696c.441.062.612.636.282.95l-3.522 3.356.83 4.73c.078.443-.35.792-.746.592L8 13.187l-4.389 2.256z"/>
</svg>

<h5>{{ item.offre.titre }}</h5>



<p>{{ item.offre.entreprise }} - {{ item.offre.ville }}</p>

<a href="#" class="btn" style="background-color:#73986f; color:white;">
Voir l'offre
</a>
</div>

</div>

</div>

{% endfor %}
{% endblock %}
