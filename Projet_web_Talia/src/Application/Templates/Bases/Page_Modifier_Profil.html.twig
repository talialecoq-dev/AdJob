{% extends 'Bases/Base.html.twig' %}

{% block title %}Modifier mon Profil - AdJob
{% endblock %}

{% block content %}
	<div class="container py-5" style="max-width: 700px;">
		<div class="card shadow-lg border-0" style="border-radius: 1rem;">
			<div class="card-body p-5">

				<h4 class="fw-bold mb-4 text-center" style="color: #4a5d43;">Modifier mon profil</h4>

				<form method="POST" action="/Profil/Modifier" enctype="multipart/form-data">


					<div class="text-center mb-4">
						{% if user.logo %}
							<img src="/uploads/{{ user.logo }}" class="rounded-circle shadow-sm mb-2" style="width: 120px; height: 120px; object-fit: cover; border: 4px solid #97a48a;">
						{% else %}
							<img src="/Images/Image_Profil.png" class="rounded-circle shadow-sm mb-2" style="width: 120px; height: 120px; object-fit: cover; border: 4px solid #ccc;">
						{% endif %}
						<div class="mt-2">
							<label class="form-label fw-bold">Changer la photo de profil</label>
							<input type="file" name="image_profil" class="form-control" accept="image/*">
						</div>
					</div>


					<div class="mb-3">
						<label class="form-label fw-bold">Nom</label>
						<input type="text" name="nom" class="form-control" value="{{ user.nom }}" required>
					</div>

					<div class="mb-3">
						<label class="form-label fw-bold">Prénom</label>
						<input type="text" name="prenom" class="form-control" value="{{ user.prenom }}" required>
					</div>

					<div class="mb-3">
						<label class="form-label fw-bold">Email</label>
						<input type="email" name="email" class="form-control" value="{{ user.email }}" required>
					</div>

					<div class="mb-3">
						<label class="form-label fw-bold">Nouveau mot de passe
							<span class="text-muted fw-normal" style="font-size:0.85rem;">(laisser vide pour ne pas changer)</span>
						</label>
						<input type="password" name="mot_de_passe" class="form-control" placeholder="Nouveau mot de passe">
					</div>


					{% if user.role.value == 'etudiant' %}
						<div class="mb-3">
							<label class="form-label fw-bold">Adresse</label>
							<input type="text" name="adresse" class="form-control" value="{{ user.adresse ?? '' }}">
						</div>
						<div class="mb-3">
							<label class="form-label fw-bold">Ville</label>
							<input type="text" name="ville" class="form-control" value="{{ user.ville ?? '' }}">
						</div>
						<div class="mb-3">
							<label class="form-label fw-bold">Région</label>
							<input type="text" name="region" class="form-control" value="{{ user.region ?? '' }}">
						</div>
					{% endif %}


					{% if user.role.value == 'pilote' %}
						<div class="mb-3">
							<label class="form-label fw-bold">Localisation</label>
							<input type="text" name="localisation" class="form-control" value="{{ user.localisation ?? '' }}">
						</div>
					{% endif %}


					<div class="mb-4">
						<label class="form-label fw-bold">Campus</label>
						<select name="campus" class="form-select">
							{% for c in campusList %}
								<option value="{{ c.nomVille }}" {% if user.campus and user.campus.nomVille == c.nomVille %} selected {% endif %}>
									{{ c.nomVille }}
								</option>
							{% endfor %}
						</select>
					</div>


					<div class="d-flex gap-3">
						<button type="submit" class="btn flex-fill text-white" style="background-color: #4a5d43;">
							Enregistrer
						</button>
						<a href="/Profil" class="btn flex-fill" style="background-color: #a0a890; color: white;">
							Annuler
						</a>
					</div>

				</form>
			</div>
		</div>
	</div>
{% endblock %}
