{% extends "Bases/Base.html.twig" %}

{% block title %}Candidatures - AdJob
{% endblock %}

{% block content %}
	<div class="container-fluid p-4" style="background-color: #eed4cb; min-height: 100vh;">

		{% if candidatures is empty %}
			<p class="text-muted">Aucune candidature pour le moment.</p>
		{% else %}
			{% for c in candidatures %}
				<div class="card mb-3" style="max-width: 750px; padding: 20px; border: 3px solid #a0a890; border-radius: 15px;">
					<div class="row g-0 align-items-center">

						<div class="col-md-2">
							<img src="{{ c.image }}" class="img-fluid rounded" style="max-height: 200px">
						</div>

						<div class="col-md-10">
							<div class="card-body">
								<h5 class="card-title" style="color: #8fa882">{{ c.titre}}</h5>
								<p class="text-muted mb-1" style="font-size: 0.9rem;">{{ c.entreprise }}</p>
								<p class="mb-1" style="front-style">{{o.domaine}}</p>
								<span class="badge rounded-pill bg-{{ c.color }} text-dark">{{c.statut }}</span>
								<p class="card-text mt-2">{{ c.desc }}</p>

								<div class="d-flex gap-2 mt-3">


									<a href="/?recherche={{ c.titre|url_encode }}" class="btn btn-sm" style="background-color: #a0a890; color: white; border: none; padding: 8px 12px;">
										Voir l'offre
									</a>

									<form method="POST" action="/Supprimer-Candidature/{{ c.id }}">
										<button type="submit" class="btn btn-sm" style="background-color: #e07070; color: white; border: none; padding: 8px 12px;">
											Supprimer
										</button>
									</form>

								</div>
							</div>
						</div>

					</div>
				</div>
			{% endfor %}

		</div>
	{% endif %}
{% endblock %}
