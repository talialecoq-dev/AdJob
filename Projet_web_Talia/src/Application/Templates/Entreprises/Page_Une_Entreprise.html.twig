<div class="container-fluid px-4 my-5">
  <div class="row row-cols-1 row-cols-md-4 g-4">

    {% for entreprise in entreprises %}
    <div class="col">
      <div class="card border-0 overflow-hidden h-100"
           style="border-radius:2rem; background-color:#97a48a;">

        <div style="height:220px; overflow:hidden; border-radius:2rem 2rem 0 0;">
          <img src="/uploads/{{ entreprise.image }}"
               alt="Image de {{ entreprise.nom }}"
               style="width:100%; height:100%; object-fit:cover;">
        </div>

        <div class="card-body px-5 pt-4 pb-4 d-flex flex-column gap-3">

          <h1 class="text-white fw-bold mb-0" style="font-size:1.5rem;">
            {{ entreprise.nom }}
          </h1>

          <div class="d-flex flex-wrap gap-2">
            <span class="badge rounded-pill border text-dark fw-normal px-3 py-2"
                  style="background-color:#ffffff;">{{ entreprise.secteur }}</span>
          </div>

          <div class="d-flex gap-2 mt-auto">
            <button type="button" class="btn flex-fill"
                    data-bs-toggle="modal"
                    data-bs-target="#modal{{ entreprise.id }}"
                    style="background-color:#e0c7bf; color:black; border:none; border-radius:0.6rem;">
              En savoir plus
            </button>
            <a href="{{ entreprise.siteWeb }}" target="_blank"
               class="btn flex-fill"
               style="background-color:#e0c7bf; color:black; border:none; border-radius:0.6rem;">
              Visiter le site
            </a>
          </div>

        </div>
      </div>
    </div>
    {% endfor %}

  </div>
</div>